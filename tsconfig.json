{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0" ,

    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "strict": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowJs": true,
    "noEmit": true,

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    },

   "types": ["vite/client", "node"]
  },

  "include": [
    "src"
  ]
}